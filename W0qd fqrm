-- ====================================================================
-- SETTINGS TAB
-- ====================================================================

-- Action Delay Input
SettingsTab:Input({
    Title = "Action Delay (0.01-1.0)",
    Placeholder = "0.1",
    Callback = function(text)
        local num = tonumber(text)
        if num and num >= 0.01 and num <= 1.0 then
            actionDelay = num
        end
    end
})

-- Stop All Button
SettingsTab:Button({
    Title = "Stop All Automation",
    Callback = function()
        autoAxeSpeed = false
        autoAxeLevel = false
        autoChipper = false
        autoStump = false
        autoStumpBuy = false
        autoLuck = false
        autoSpinStand = false
    end
})
