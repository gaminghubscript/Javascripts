local Rayfield = loadstring(game:HttpGet('https://sirius.menu/rayfield'))()

local Window = Rayfield:CreateWindow({
    Name = "Chicken Farm | Goldbed",
    LoadingTitle = "Loading Automation...",
    LoadingSubtitle = "by Goldbed",
    ConfigurationSaving = {
        Enabled = false
    },
    Discord = {
        Enabled = false
    },
    KeySystem = false
})

local Tab = Window:CreateTab("Automation", 4483362458)

local AutoBuy = false
local BuyAmount = 1 -- Default amount
local AutoMerge = false
local AutoCollect = false
local AutoUpgrade = false
local AutoDeposit = false

-- DROPDOWN: CHOOSE BUY AMOUNT
Tab:CreateDropdown({
    Name = "Buy Amount",
    Options = {"1", "5", "25", "100"},
    CurrentOption = {"1"},
    MultipleOptions = false,
    Flag = "BuyAmountDropdown",
    Callback = function(Option)
        BuyAmount = tonumber(Option[1])
    end,
})

-- TOGGLE 1: AUTO BUY CHICKENS
Tab:CreateToggle({
    Name = "Auto Buy Chickens",
    CurrentValue = false,
    Flag = "AutoBuyChickensToggle", 
    Callback = function(Value)
        AutoBuy = Value
        
        task.spawn(function()
            while AutoBuy do
                local args = {
                    "Buy Chickens",
                    BuyAmount
                }
                
                local remote = game:GetService("ReplicatedStorage")
                    :WaitForChild("Paper", 2)
                    :WaitForChild("Remotes", 2)
                    :WaitForChild("__remotefunction", 2)
                
                if remote then
                    remote:InvokeServer(unpack(args))
                else
                    break
                end
                
                task.wait(0.5)
            end
        end)
    end,
})

