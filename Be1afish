MainTab:Toggle({
    Title = "Noclip",
    Desc = "Walk through walls.",
    Value = false,
    Callback = function(state)
        _G.NoclipActive = state 
        if _G.NoclipActive then 
            if _G.NoclipConnection then _G.NoclipConnection:Disconnect() end 
            _G.NoclipConnection = RunService.Stepped:Connect(function() 
                local character = Player.Character 
                if character then 
                    for _, part in pairs(character:GetDescendants()) do 
                        if part:IsA("BasePart") then part.CanCollide = false end 
                    end 
                end 
            end) 
        else 
            if _G.NoclipConnection then 
                _G.NoclipConnection:Disconnect() 
                _G.NoclipConnection = nil 
            end 
        end
    end
})

MainTab:Toggle({
    Title = "Fly",
    Desc = "Fly around using WASD.",
    Value = false,
    Callback = function(state)
        local function setFly(enabled) 
            local character = Player.Character 
            local hrp = character and character:FindFirstChild("HumanoidRootPart") 
            if enabled then 
                if not hrp then return end 
                _G.flyVelocity = Instance.new("BodyVelocity") 
                _G.flyVelocity.MaxForce = Vector3.new(math.huge, math.huge, math.huge) 
                _G.flyVelocity.Velocity = Vector3.new(0, 0, 0) 
                _G.flyVelocity.Parent = hrp 
                
                _G.flyGyro = Instance.new("BodyGyro") 
                _G.flyGyro.MaxTorque = Vector3.new(math.huge, math.huge, math.huge) 
                _G.flyGyro.P = 10000 
                _G.flyGyro.D = 100 
                _G.flyGyro.CFrame = hrp.CFrame 
                _G.flyGyro.Parent = hrp 
                
                task.spawn(function() 
                    while _G.FlyActive and character and hrp do 
                        local cameraCFrame = workspace.CurrentCamera.CFrame 
                        local moveDir = Vector3.new(0, 0, 0) 
                        if UserInputService:IsKeyDown(Enum.KeyCode.W) then moveDir = moveDir + cameraCFrame.LookVector end 
                        if UserInputService:IsKeyDown(Enum.KeyCode.S) then moveDir = moveDir - cameraCFrame.LookVector end 
                        if UserInputService:IsKeyDown(Enum.KeyCode.A) then moveDir = moveDir - cameraCFrame.RightVector end 
                        if UserInputService:IsKeyDown(Enum.KeyCode.D) then moveDir = moveDir + cameraCFrame.RightVector end 
                        _G.flyVelocity.Velocity = moveDir * 50 
                        _G.flyGyro.CFrame = cameraCFrame 
                        task.wait() 
                    end 
                end) 
            else 
                if _G.flyVelocity then _G.flyVelocity:Destroy() end 
                if _G.flyGyro then _G.flyGyro:Destroy() end 
            end 
        end 
        _G.FlyActive = state 
        setFly(_G.FlyActive)
    end
})

