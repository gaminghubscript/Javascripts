AutoTab:Toggle({
    Title = "Auto Fish V1 (Input Interface Method)",
    Desc = "Uses standard UI scanning & screen clicks to fish while bypassing cutscenes.",
    Value = false,
    Callback = function(state)
        _G.AutoFishV1Active = state 
        if _G.AutoFishV1Active then 
            autoFishV1Task = task.spawn(function() 
                while _G.AutoFishV1Active do 
                    pcall(function()
                        local character = Player.Character
                        local hrp = character and character:FindFirstChild("HumanoidRootPart")
                        local zone = findFishingZone()
                        
                        if zone and hrp then
                            local dist = (hrp.Position - zone.Position).Magnitude
                            if dist > 20 then
                                hrp.CFrame = CFrame.new(zone.Position + Vector3.new(0, 5, 0))
                                task.wait(1)
                            end
                        end
                        
                        if clickFishButton() then
                            task.wait(CONFIG.fishCastDelay)
                            bypassCutscenes() -- Clean skip logic invoked safely here
                            
                            local waitStart = tick()
                            while tick() - waitStart < 10 and _G.AutoFishV1Active do 
                                if lastFishTime > waitStart then break end 
                                
                                clickFishButton()
                                
                                local cam = workspace.CurrentCamera
                                local cx, cy = cam.ViewportSize.X / 2, cam.ViewportSize.Y / 2
                                Vim:SendMouseButtonEvent(cx, cy, 0, true, game, 1)
                                task.wait(0.02)
                                Vim:SendMouseButtonEvent(cx, cy, 0, false, game, 1)
                                
                                task.wait(0.1)
                            end
                            
                            task.wait(CONFIG.fishReelDelay)
                            clickFishButton()
                        else
                            local cam = workspace.CurrentCamera
                            local cx, cy = cam.ViewportSize.X / 2, cam.ViewportSize.Y / 2
                            Vim:SendMouseButtonEvent(cx, cy, 0, true, game, 1)
                            task.wait(0.05)
                            Vim:SendMouseButtonEvent(cx, cy, 0, false, game, 1)
                        end
                    end)
                    task.wait(CONFIG.fishLoopDelay)
                end 
            end) 
        else 
            if autoFishV1Task then task.cancel(autoFishV1Task) autoFishV1Task = nil end 
        end
    end
})

AutoTab:Toggle({
    Title = "Auto Fish V2 (Payload Version)",
    Desc = "Fires fishing network payloads directly synced with an anti-glitch delay.",
    Value = false,
    Callback = function(state)
        _G.AutoFishV2Active = state 
        if _G.AutoFishV2Active then 
            autoFishV2Task = task.spawn(function() 
                local targetRemote = ReplicatedStorage:WaitForChild("shared/network@globalEvents"):WaitForChild("castFishingHook")
                
                while _G.AutoFishV2Active do 
                    pcall(function()
                        local character = Player.Character
                        local hrp = character and character:FindFirstChild("HumanoidRootPart")
                        local zone = findFishingZone()
                        
                        if zone and hrp and (hrp.Position - zone.Position).Magnitude > 25 then
                            hrp.CFrame = CFrame.new(zone.Position + Vector3.new(0, 5, 0))
                            task.wait(0.4)
                        end
                        
                        if hrp and targetRemote then
                            targetRemote:FireServer({
                                direction = Vector3.new(0, 0, 1),
                                startPosition = hrp.Position,
                                utilizedPowerFraction = 1,
                                peakBias = 0.35,
                                skillCheckStrength = 100
                            })
                        end
                    end)
                    task.wait(FIXED_FISH_DELAY)
                end 
            end) 
        else 
            if autoFishV2Task then task.cancel(autoFishV2Task) autoFishV2Task = nil end 
        end
    end
})

