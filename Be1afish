-- Configuration variables linked to UI or standard defaults
local CONFIG = {
    fishCastDelay = 1.0,
    fishReelDelay = 0.3,
    fishLoopDelay = 1.5,
}
local FIXED_FISH_DELAY = 6 -- Locked backup safety delay for V2

-- Tracking variables
local lastFishTime = 0
local fishCaughtCount = 0

-- Cobalt Cutscene Bypass Remotes
local cameraReturnedToPier = ReplicatedStorage:WaitForChild("shared/network@globalEvents"):WaitForChild("cameraReturnedToPier")
local castCutsceneRigSuspendRequested = ReplicatedStorage:WaitForChild("shared/network@globalEvents"):WaitForChild("castCutsceneRigSuspendRequested")
local fishLanded = ReplicatedStorage:WaitForChild("shared/network@globalEvents"):FindFirstChild("fishLanded")

if fishLanded then
    fishLanded.OnClientEvent:Connect(function(...)
        lastFishTime = tick()
        fishCaughtCount = fishCaughtCount + 1
    end)
end

local function bypassCutscenes()
    pcall(function()
        cameraReturnedToPier:FireServer()
        castCutsceneRigSuspendRequested:FireServer()
    end)
end

local function performCollectCash() 
    local globalFunctions = ReplicatedStorage:WaitForChild("shared/network@globalFunctions") 
    local userId = tostring(Player.UserId) 
    local args = {0, userId} 
    globalFunctions:WaitForChild("collectPlotMoney"):FireServer(unpack(args)) 
end 

local function equipBestFish(tierNumber) 
    local remote = ReplicatedStorage:WaitForChild("shared/network@globalFunctions"):WaitForChild("equipBestAquariumFish") 
    local safeTier = math.clamp(tierNumber, 1, 20) 
    local args = { safeTier } 
    remote:FireServer(unpack(args)) 
end 

local autoFishV1Task, autoFishV2Task, autoCollectTask, autoEquipFishTask, autoRebirthTask, autoUpgradeTask

local function findFishingZone()
    local map = Workspace:FindFirstChild("Map")
    if map then
        local fa = map:FindFirstChild("FishingArea")
        if fa then
            local zone = fa:FindFirstChild("FishingZone")
            if zone then return zone end
        end
    end
    for _, d in pairs(Workspace:GetDescendants()) do
        if d.Name == "FishingZone" and d:IsA("BasePart") then return d end
    end
    return nil
end

-- Re-implemented direct UI scanning input engine
local function clickFishButton()
    local playerGui = Player:WaitForChild("PlayerGui")
    local inset = GuiService:GetGuiInset()
    local clicked = false
    
    for _, d in pairs(playerGui:GetDescendants()) do
        if clicked then break end
        pcall(function()
            if (d:IsA("TextLabel") or d:IsA("TextButton")) and d.Text:lower():find("fish") then
                local p = d.Parent
                while p and p ~= playerGui do
                    if p:IsA("GuiButton") or p:IsA("ImageButton") or p:IsA("TextButton") then
                        local cx = p.AbsolutePosition.X + (p.AbsoluteSize.X / 2) + inset.X
                        local cy = p.AbsolutePosition.Y + (p.AbsoluteSize.Y / 2) + inset.Y
                        Vim:SendMouseButtonEvent(cx, cy, 0, true, game, 1)
                        task.wait(0.05)
                        Vim:SendMouseButtonEvent(cx, cy, 0, false, game, 1)
                        clicked = true
                        return
                    end
                    p = p.Parent
                end
            end
        end)
    end
    return clicked
end

